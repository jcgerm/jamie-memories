# Supabase
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Cloudflare Stream
VITE_CF_ACCOUNT_ID=your_cloudflare_account_id
# NOTE: Video uploads go through your Netlify serverless function — 
# the Stream API token is stored there, NOT here (never expose it client-side)

# Admin password (for the /admin page)
VITE_ADMIN_PASSWORD=choose_a_strong_password
