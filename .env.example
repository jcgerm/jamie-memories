# Supabase (VITE_ prefix = exposed to browser, needed for photo URL construction)
VITE_SUPABASE_URL=your_supabase_project_url

# These go in Cloudflare Pages dashboard as environment variables (NOT prefixed)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cloudflare Stream
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_STREAM_TOKEN=your_cloudflare_stream_api_token

# Admin
ADMIN_PASSWORD=choose_a_strong_password
VITE_ADMIN_PASSWORD=same_password_as_above
